{
  "name": "ssu-mails-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute ssu-mails --file=schema.sql",
    "db:init:remote": "wrangler d1 execute ssu-mails --remote --file=schema.sql",
    "cron:test": "wrangler dev --test-scheduled"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.0.0",
    "wrangler": "^3.0.0"
  }
}
